# Copy this file to .env and fill in your local paths.
# .env is gitignored and never committed.
#
# TLS_DATA_ROOT: directory containing:
#   processed/tls_graphs.pt          (built by nb03, or download from Zenodo)
#   processed/rcc_visium_labeled.h5ad
#   processed/rcc_pca_reference.npz
#   processed/tls_predictions.csv    (written by scripts/train.py)
#   processed/tls_embeddings.pt      (written by scripts/train.py)
#   splits/arch_config.json          (built by nb03)
#   splits/sample_splits.json        (built by nb03)
#
# TLS_PROJECT_ROOT: only needed if not running from the repo root directory.

TLS_DATA_ROOT=/path/to/your/data
# TLS_PROJECT_ROOT=/path/to/tls_functional_score
